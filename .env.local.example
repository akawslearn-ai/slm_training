# Copy to .env.local and fill in real values. NEVER commit .env.local.
#
#   cp .env.local.example .env.local
#   source .env.local && export MODAL_TOKEN_ID MODAL_TOKEN_SECRET
#
# Modal: https://modal.com  -> Settings -> API Tokens
# Only needed if `modal profile current` does not already resolve a profile
# (i.e. you have not run `modal token new` on this machine).
MODAL_TOKEN_ID=ak-XXXXXXXX
MODAL_TOKEN_SECRET=as-XXXXXXXX

# HuggingFace: https://huggingface.co/settings/tokens (role: WRITE)
# Not needed for Phases 0-4 -- all three datasets are ungated.
# Required only to push the trained MODEL in Phase 6.
HUGGINGFACE_TOKEN=hf_XXXXXXXX
