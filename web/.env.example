# Copy to .env.local for local dev, and set the same two variables in
# Vercel -> Project -> Settings -> Environment Variables for production.
#
# Both are server-only (no NEXT_PUBLIC_ prefix), so they are never shipped to
# the browser. The playground calls /api/generate, which attaches the key
# server-side before proxying to Modal.

# Printed by `modal deploy serve_app.py`. No trailing slash.
MODAL_ENDPOINT_URL=https://<workspace>--slm-125m-serve-server-web.modal.run

# Must match the SLM_API_KEY value in the Modal secret `slm-api-key`.
# Rotate with: modal secret create slm-api-key SLM_API_KEY=<new> --force
MODAL_API_KEY=

# ---------------------------------------------------------------------------
# Optional: shared rate-limit counter.
#
# Without these, rate limiting falls back to a per-instance in-memory map --
# a speed bump, not a control, since each serverless instance counts separately.
# With them, the counter is shared across all instances and actually holds.
#
# Create a free Redis database at https://console.upstash.com, then copy the
# two REST values from its "REST API" tab.
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
